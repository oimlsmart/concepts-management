---
import Layout from "@/layouts/Layout.astro";
import TermDetailPage from "@/islands/TermDetailPage.vue";
import termsSlim from "@/data/terms-slim.json";

export function getStaticPaths() {
  return (termsSlim as any[]).map(t => ({
    params: { slug: t.slug },
    props: { slug: t.slug },
  }));
}

const { slug } = Astro.props;
---
<Layout>
  <TermDetailPage client:only="vue" slug={slug} />
</Layout>
